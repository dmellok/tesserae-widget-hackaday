{
  "tesserae_compat": "1.x",
  "name": "News, Hackaday",
  "version": "0.1.2",
  "kind": "widget",
  "description": "Latest articles from Hackaday, the hardware-hacking publication, with the Jolly Wrencher in the header. Pick the hero layout for a featured image up top, or the list layout for a tighter run of headlines. Pure RSS, no API key.",
  "icon": "ph-skull",
  "supports": {
    "sizes": ["sm", "md", "lg"]
  },
  "cell_options": [
    {
      "name": "label",
      "type": "string",
      "label": "Title",
      "default": "Hackaday"
    },
    {
      "name": "layout",
      "type": "select",
      "label": "Layout",
      "default": "list",
      "choices": [
        {"value": "list", "label": "List of headlines"},
        {"value": "hero", "label": "Hero with featured image"}
      ]
    },
    {
      "name": "max_items",
      "type": "number",
      "label": "Max headlines",
      "default": 5,
      "min": 1,
      "max": 12
    },
    {
      "name": "show_author",
      "type": "boolean",
      "label": "Show author byline",
      "default": true
    }
  ],
  "render": {
    "dither": "none",
    "needs_network": true
  }
}
